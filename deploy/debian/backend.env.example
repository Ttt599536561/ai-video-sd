# Copy this file to /etc/ai-video/backend.env on the Debian server.
# Keep it readable only by root and the ai-video service group:
#   sudo chown root:ai-video /etc/ai-video/backend.env
#   sudo chmod 0640 /etc/ai-video/backend.env

NODE_ENV=production
# If another project already uses 4000, change this to 4100 or another free
# localhost-only port, and update the Nginx proxy_pass target to match.
PORT=4000

# Use a URL-safe database password, or URL-encode special characters.
DATABASE_URL="postgresql://ai_video_user:REPLACE_DB_PASSWORD@127.0.0.1:5432/ai_video"
USE_IN_MEMORY_STORE=false

# Generate with:
#   openssl rand -base64 48
JWT_SECRET="REPLACE_WITH_RANDOM_SECRET"
REDEMPTION_HASH_SECRET="REPLACE_WITH_RANDOM_SECRET"

# Set only for first-admin creation. Remove or comment out after bootstrap.
BOOTSTRAP_ADMIN_SECRET="REPLACE_USE_ONCE_SECRET"

# Generate with:
#   openssl rand -base64 32
MODEL_CONFIG_ENCRYPTION_KEY_BASE64="REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY"

# For production key rotation later, prefer this keyring format instead of the
# single MODEL_CONFIG_ENCRYPTION_KEY_BASE64 value above:
# MODEL_CONFIG_ENCRYPTION_KEYS="1:base64:OLD_32_BYTE_KEY,2:base64:NEW_32_BYTE_KEY"
# MODEL_CONFIG_ENCRYPTION_CURRENT_KEY_VERSION=2

REDIS_URL="redis://127.0.0.1:6379"

# Backend-only supplier settings. Never put these values into frontend files.
VIDEO_PROVIDER_BASE_URL="https://zz1cc.cc.cd"
VIDEO_PROVIDER_API_KEY="REPLACE_WITH_PROVIDER_API_KEY"
VIDEO_PROVIDER_REAL_JOBS=true

# Optional fallback for supplier-fetchable reference media URLs. This must be a
# public HTTPS origin that reaches this backend, for example https://ai.example.com.
# Prefer setting this from Admin -> System Settings after deployment.
# PUBLIC_API_BASE_URL="https://api.example.com"

# Persistent local video cache. The app marks generated videos expired after 3 days.
VIDEO_STORAGE_DIR="/var/lib/ai-video/storage/videos"

# JSON request body limit for base64 reference media uploads. Default is 64 MiB.
REQUEST_BODY_LIMIT_BYTES=67108864
