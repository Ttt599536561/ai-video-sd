NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_video
USE_IN_MEMORY_STORE=false
JWT_SECRET=change-me-in-production
REDEMPTION_HASH_SECRET=change-me-too
BOOTSTRAP_ADMIN_SECRET=use-once-then-remove
MODEL_CONFIG_ENCRYPTION_KEY_BASE64=base64-32-byte-key
# For production rotation, prefer a versioned keyring instead of the single key above:
# MODEL_CONFIG_ENCRYPTION_KEYS=1:base64:old-32-byte-key,2:base64:new-32-byte-key
# MODEL_CONFIG_ENCRYPTION_CURRENT_KEY_VERSION=2
REDIS_URL=redis://localhost:6379
# PUBLIC_API_BASE_URL=https://your-public-api.example.com
VIDEO_PROVIDER_REAL_JOBS=false
VIDEO_STORAGE_DIR=storage/videos
REQUEST_BODY_LIMIT_BYTES=67108864
